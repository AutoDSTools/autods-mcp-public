MCP_ENV=local
COGNITO_USER_POOL_ID=us-west-2_qwerty
COGNITO_REGION=us-west-2
ALLOWED_COGNITO_CLIENT_IDS=["qwerty"]

# Phase C — OAuth discovery + DCR shim. COGNITO_PUBLIC_CLIENT_ID and
# COGNITO_DOMAIN are required in every environment; the settings refuse to
# boot without them.
# COGNITO_PUBLIC_CLIENT_ID is returned by /oauth/register; must also be in
# ALLOWED_COGNITO_CLIENT_IDS or the settings will refuse to boot.
COGNITO_PUBLIC_CLIENT_ID=qwerty
# Cognito Hosted UI domain — bare hostname or full URL.
COGNITO_DOMAIN=auth.example.com
# Allowlisted redirect URIs the DCR shim will echo back. Mirror the URIs
# pre-registered on the Cognito client itself.
MCP_REGISTRATION_REDIRECT_URIS=["https://claude.com/api/mcp/auth_callback","https://claude.ai/api/mcp/auth_callback","http://localhost:6274/oauth/callback","http://localhost:8000/callback"]

LOG_LEVEL=DEBUG
